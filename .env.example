# --- Model selection ---
VLLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
VLLM_MODEL_LOCAL=HuggingFaceTB/SmolLM2-135M-Instruct

# --- vLLM server ---
VLLM_API_KEY=change-me
TENSOR_PARALLEL_SIZE=2
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=8192
PORT=8000

# --- Hugging Face (Llama-3.3 is gated) ---
HF_TOKEN=hf_xxx

# --- Clients (frontend, loadtest, test) ---
VLLM_BASE_URL=http://localhost:8000/v1

# --- MLflow (runs on your local PC, not on RunPod) ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=vllm-loadtest
