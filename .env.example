# --- Model selection ---
VLLM_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
VLLM_MODEL_LOCAL=HuggingFaceTB/SmolLM2-135M-Instruct

# --- vLLM server ---
VLLM_API_KEY=change-me
TENSOR_PARALLEL_SIZE=2
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=32768
BLOCK_SIZE=16
# Optional upper bound on batched sequences. Empty = vLLM default (1024).
# Raise it (e.g. 512, 1024, 2000) to load-test; real limit is KV-cache memory.
MAX_NUM_SEQS=
PORT=8000

# --- Hugging Face (optional: Qwen3-Coder is Apache-2.0, not gated) ---
# Only set this to avoid download rate limits.
HF_TOKEN=

# --- RunPod control (for stop_runpod.ps1) ---
# Account API key from RunPod Settings -> API Keys (NOT VLLM_API_KEY).
RUNPOD_API_KEY=
RUNPOD_POD_ID=

# --- Clients (frontend, loadtest, test, client_runpod) ---
# localhost is LOCAL-ONLY. To test the RunPod pod, REPLACE the line below with the
# pod's public URL (https, port lives in the hostname, keep /v1). `make url-runpod`
# prints it for you:
#   VLLM_BASE_URL=https://<pod-id>-8000.proxy.runpod.net/v1
VLLM_BASE_URL=http://localhost:8000/v1

# --- MLflow (runs on your local PC, not on RunPod) ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=vllm-loadtest
